{
  "name": "@keyhub/domain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "default": "./dist/keys.js"
    },
    "./batch": {
      "types": "./src/batch.ts",
      "default": "./dist/batch.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
