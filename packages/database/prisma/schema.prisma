generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum KeyStatus {
  PENDING
  SUBMITTING
  SUBMITTED
  TEST_FAILED
  RETRYING
  UPSTREAM_ERROR
}

enum ConnectionStatus {
  UNCONFIGURED
  CONNECTING
  CONNECTED
  DEGRADED
  BLOCKED
}

enum JobStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id             String      @id @default(cuid())
  username       String      @unique
  passwordHash   String
  role           UserRole    @default(USER)
  isActive       Boolean     @default(true)
  sessionVersion Int         @default(1)
  keys           KeyRecord[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model KeyRecord {
  id                String     @id @default(cuid())
  ownerId           String
  owner             User       @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  encryptedKey      String
  encryptionIv      String
  encryptionTag     String
  keyFingerprint    String     @unique
  maskedKey         String
  keySuffix         String
  warrantyHours     Int
  upstreamChannelId String?
  upstreamItemId    String?    @unique
  status            KeyStatus  @default(PENDING)
  testResult        String?
  accessStatus      String?
  usageUsd          Decimal    @default(0) @db.Decimal(18, 6)
  usageSiteCount    Int        @default(0)
  sampledAt         DateTime?
  submittedAt       DateTime?
  failureCode       String?
  failureMessage    String?
  jobs              JobRun[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([ownerId, createdAt])
  @@index([status, updatedAt])
}

model UpstreamConnection {
  id                    String           @id @default("primary")
  encryptedUsername     String?
  usernameIv            String?
  usernameTag           String?
  encryptedPassword     String?
  passwordIv            String?
  passwordTag           String?
  encryptedSessionState String?
  sessionIv             String?
  sessionTag            String?
  upstreamChannelId     String?
  status                ConnectionStatus @default(UNCONFIGURED)
  lastLoginAt           DateTime?
  lastSuccessAt         DateTime?
  lastFailureAt         DateTime?
  lastSyncAt            DateTime?
  failureCode           String?
  failureMessage        String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model JobRun {
  id             String     @id @default(cuid())
  jobType        String
  keyRecordId    String?
  keyRecord      KeyRecord? @relation(fields: [keyRecordId], references: [id], onDelete: SetNull)
  queueJobId     String?
  status         JobStatus  @default(RUNNING)
  attempt        Int        @default(1)
  resultCode     String?
  resultMessage  String?
  startedAt      DateTime   @default(now())
  finishedAt     DateTime?
  createdAt      DateTime   @default(now())

  @@index([keyRecordId, createdAt])
  @@index([jobType, createdAt])
}
